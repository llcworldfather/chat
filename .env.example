# API base (include /api)
REACT_APP_API_URL=http://localhost:5000/api

# Local dev: CRA loads .env.development before .env; variables already set (e.g. empty in .env.local) are NOT overwritten.
# Use .env.development for REACT_APP_* when running npm start, then restart the dev server.

# Firebase Web app config (Console → Project settings → Your apps)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Cloud Messaging → Web configuration → Web Push certificates (public key only)
REACT_APP_FCM_VAPID_KEY=

# Also copy the same Firebase config into public/firebase-messaging-sw.js (replace REPLACE_ME).
